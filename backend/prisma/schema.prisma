generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Grade {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
}

enum Subject {
  MATH
  VIETNAMESE
  ENGLISH
  SCIENCE
  HISTORY
  GEOGRAPHY
  ART
  MUSIC
  PE
  LIFE_SKILLS
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCHING
}

enum GameType {
  MATH_QUIZ
  WORD_MATCHING
  MEMORY_CARD
  PUZZLE
}

enum AchievementType {
  COURSE_COMPLETION
  QUIZ_MASTER
  GAME_CHAMPION
  STREAK_KEEPER
  LEVEL_UP
}

enum NotificationType {
  ACHIEVEMENT_UNLOCKED
  QUIZ_GRADED
  COURSE_COMPLETED
  PARENT_MESSAGE
  SYSTEM
}

enum ActivityType {
  LOGIN
  LOGOUT
  COURSE_ENROLLED
  LECTURE_VIEWED
  QUIZ_ATTEMPTED
  GAME_PLAYED
  ACHIEVEMENT_UNLOCKED
}

enum ReportType {
  DAILY
  WEEKLY
}

enum RewardType {
  EARN
  SPEND
  BONUS
  PENALTY
  REFUND
}

enum RewardCategory {
  LESSON_COMPLETE
  QUIZ_COMPLETE
  GAME_PLAY
  STREAK_BONUS
  LEVEL_UP
  SHOP_PURCHASE
  ACHIEVEMENT_UNLOCK
  AI_CHAT
  DAILY_LOGIN
}

enum Currency {
  XP
  COIN
  STAR
}

enum ShopItemType {
  AVATAR
  STICKER
  BADGE
  STREAK_SHIELD
  THEME
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  googleId      String?   @unique
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student        Student?
  parent         Parent?
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]
  chatSessions   ChatSession[]
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verifications")
}

model Student {
  id             String   @id @default(uuid())
  userId         String   @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  grade          Grade
  avatar         String?
  avatarSeed     String?  @db.VarChar(50)
  bio            String?  @db.Text
  preferences    Json?
  xp             Int      @default(0) @db.UnsignedInt
  level          Int      @default(1) @db.UnsignedInt
  stars          Int      @default(0) @db.UnsignedInt
  streak         Int      @default(0) @db.UnsignedInt
  coins          Int      @default(0) @db.UnsignedInt
  lastActiveDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Parent?              @relation(fields: [parentId], references: [id])
  parentId     String?
  enrollments  Enrollment[]
  progress     Progress[]
  quizAttempts QuizAttempt[]
  gameScores   GameScore[]
  achievements StudentAchievement[]
  reviews      CourseReview[]
  transactions RewardTransaction[]
  purchases    ShopPurchase[]
  streakShields StreakShield[]

  @@index([userId])
  @@index([parentId])
  @@index([grade])
  @@index([level])
  @@index([xp])
  @@map("students")
}

model Parent {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Student[]
  monitoringSubscriptions MonitoringSubscription[]

  @@index([userId])
  @@index([email])
  @@map("parents")
}

model Course {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String      @db.Text
  thumbnail   String?
  subject     Subject
  grade       Grade
  level       CourseLevel @default(BEGINNER)
  duration    Int         @db.UnsignedInt
  isPublished Boolean     @default(false)
  isFree      Boolean     @default(true)
  order       Int         @default(0) @db.UnsignedInt
  metadata    Json?
  avgRating   Float?      @default(0)
  reviewCount Int         @default(0) @db.UnsignedInt
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lectures    Lecture[]
  enrollments Enrollment[]
  quizzes     Quiz[]
  reviews     CourseReview[]

  @@index([slug])
  @@index([subject])
  @@index([grade])
  @@index([isPublished])
  @@index([avgRating])
  @@map("courses")
}

model Lecture {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  slug        String   @unique
  description String?  @db.Text
  videoUrl    String?
  duration    Int      @db.UnsignedInt
  order       Int      @default(0) @db.UnsignedInt
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@index([courseId])
  @@index([order])
  @@index([slug])
  @@map("lectures")
}

model Enrollment {
  id           String   @id @default(uuid())
  studentId    String
  courseId     String
  enrolledAt   DateTime @default(now())
  completedAt  DateTime?
  progress     Float    @default(0)
  lastAccessAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([progress])
  @@map("enrollments")
}

model Progress {
  id             String   @id @default(uuid())
  studentId      String
  lectureId      String
  isCompleted    Boolean  @default(false)
  watchedSeconds Int      @default(0) @db.UnsignedInt
  completionRate Float    @default(0)
  lastWatchedAt  DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([studentId, lectureId])
  @@index([studentId])
  @@index([lectureId])
  @@index([isCompleted])
  @@map("progress")
}

model Quiz {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  description  String?  @db.Text
  duration     Int      @db.UnsignedInt
  passingScore Int      @default(70) @db.UnsignedTinyInt
  maxAttempts  Int      @default(3) @db.UnsignedTinyInt
  order        Int      @default(0) @db.UnsignedInt
  isActive     Boolean  @default(true)
  settings     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([isActive])
  @@map("quizzes")
}

model Question {
  id            String       @id @default(uuid())
  quizId        String
  type          QuestionType
  question      String       @db.Text
  options       Json?
  correctAnswer String       @db.Text
  explanation   String?      @db.Text
  points        Int          @default(1) @db.UnsignedTinyInt
  order         Int          @default(0) @db.UnsignedInt
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId])
  @@index([order])
  @@map("questions")
}

model QuizAttempt {
  id           String   @id @default(uuid())
  quizId       String
  studentId    String
  score        Float
  totalPoints  Int      @db.UnsignedInt
  earnedPoints Int      @db.UnsignedInt
  isPassed     Boolean
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  timeSpent    Int      @default(0) @db.UnsignedInt

  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId])
  @@index([studentId])
  @@index([isPassed])
  @@index([studentId, startedAt])
  @@index([score])
  @@map("quiz_attempts")
}

model Answer {
  id           String   @id @default(uuid())
  attemptId    String
  questionId   String
  answer       String   @db.Text
  isCorrect    Boolean
  pointsEarned Int      @default(0) @db.UnsignedTinyInt
  createdAt    DateTime @default(now())

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("answers")
}

model Game {
  id          String   @id @default(uuid())
  type        GameType
  title       String
  description String   @db.Text
  subject     Subject
  grade       Grade
  thumbnail   String?
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores GameScore[]

  @@index([type])
  @@index([subject])
  @@index([grade])
  @@index([isActive])
  @@map("games")
}

model GameScore {
  id        String   @id @default(uuid())
  gameId    String
  studentId String
  score     Int      @db.UnsignedInt
  level     Int      @default(1) @db.UnsignedTinyInt
  duration  Int      @db.UnsignedInt
  playedAt  DateTime @default(now())

  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([studentId])
  @@index([score])
  @@index([studentId, playedAt])
  @@index([gameId, score])
  @@map("game_scores")
}

model Achievement {
  id          String          @id @default(uuid())
  type        AchievementType
  title       String
  description String          @db.Text
  icon        String
  xpReward    Int             @default(0) @db.UnsignedInt
  condition   Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  students StudentAchievement[]

  @@index([type])
  @@map("achievements")
}

model StudentAchievement {
  id            String   @id @default(uuid())
  studentId     String
  achievementId String
  unlockedAt    DateTime @default(now())

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementId])
  @@index([studentId])
  @@index([achievementId])
  @@index([unlockedAt])
  @@map("student_achievements")
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  studentId String
  rating    Int      @db.UnsignedTinyInt
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
  @@index([rating])
  @@map("course_reviews")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String
  type      ActivityType
  metadata  Json?
  ipAddress String?
  userAgent String?      @db.Text
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@map("activity_logs")
}

model ChatSession {
  id            String   @id @default(uuid())
  userId        String
  title         String   @default("New Chat")
  lastMessageAt DateTime @default(now())
  messageCount  Int      @default(0) @db.UnsignedInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, lastMessageAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

model MonitoringSubscription {
  id        String   @id @default(uuid())
  parentId  String
  childId   String
  reportType ReportType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, reportType])
  @@index([parentId])
  @@index([childId])
  @@map("monitoring_subscriptions")
}

model ProgressReport {
  id        String   @id @default(uuid())
  childId   String
  reportType ReportType
  periodStart DateTime
  periodEnd   DateTime
  data      Json     // Report data
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([childId, reportType, periodStart])
  @@index([childId])
  @@map("progress_reports")
}

model RewardTransaction {
  id        String   @id @default(uuid())
  studentId String
  type      RewardType
  category  RewardCategory
  amount    Int
  currency  Currency
  metadata  Json?
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([category])
  @@index([currency])
  @@map("reward_transactions")
}

model ShopItem {
  id          String   @id @default(uuid())
  type        ShopItemType
  name        String
  description String   @db.Text
  icon        String
  price       Int      @db.UnsignedInt
  currency    Currency
  requiredLevel Int?   @db.UnsignedInt
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases ShopPurchase[]

  @@index([type, isActive])
  @@index([currency])
  @@map("shop_items")
}

model ShopPurchase {
  id        String   @id @default(uuid())
  studentId String
  itemId    String
  price     Int      @db.UnsignedInt
  currency  Currency
  purchasedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item    ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([studentId, purchasedAt])
  @@index([itemId])
  @@map("shop_purchases")
}

model StreakShield {
  id        String   @id @default(uuid())
  studentId String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, expiresAt])
  @@index([usedAt])
  @@map("streak_shields")
}